  "keyFeatures": [
    "Multi-tenant SaaS architecture",
    "Retail management with POS support",
    "Purchase order management and procurement",
    "Sales order and customer management",
    "Warehouse and inventory tracking",
    "Financial accounting and reporting",
    "Material/product catalog management",
    "Advanced reporting and analytics",
    "Role-based access control (RBAC)",
    "Multi-language support (73 languages)",
    "Plugin system for extensibility",
    "Warehouse transfer and assembly/disassembly"
  ],
  "publicApiSurface": [
    "DepotController - Warehouse/depot management",
    "DepotHeadController - Warehouse transaction headers",
    "DepotItemController - Warehouse transaction items",
    "MaterialController - Product/material management",
    "MaterialCategoryController - Material categorization",
    "MaterialAttributeController - Material attributes",
    "SupplierController - Vendor/supplier management",
    "AccountController - Financial accounts",
    "AccountHeadController - Financial transaction headers",
    "AccountItemController - Financial transaction items",
    "UserController - User management",
    "TenantController - Tenant/organization management",
    "RoleController - Role and permissions",
    "OrganizationController - Organization structure",
    "FunctionController - System functions/menus",
    "SystemConfigController - System configuration",
    "PlatformConfigController - Platform settings",
    "PluginController - Plugin management"
  ]
